# Скопируй в .env и подставь свои значения:  cp .env.example .env
TOKEN=телеграм_токен_от_BotFather
# Telegram ID владельца — кому доступны /admin, /grant, /revoke
ADMIN_ID=123456789
# Необязательно: платный канал. Участник канала = есть доступ к боту.
# Бот должен быть АДМИНОМ канала. Формат: @username или -100xxxxxxxxxx. Пусто = выкл.
# CHANNEL_ID=@my_paid_channel
# Необязательно: путь к файлу БД (по умолчанию delivery.db рядом с кодом)
# DB_PATH=/data/delivery.db
